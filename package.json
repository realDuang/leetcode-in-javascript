{
  "name": "leetcode-in-javascript",
  "version": "1.0.0",
  "private": true,
  "description": "使用js/ts的leetcode题解仓库",
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "directories": {
    "doc": "docs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.13.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2"
    }
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{js,ts}\" \"docs/.vitepress/config.mts\" \"docs/.vitepress/sidebar.ts\"",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "ts-node scripts/run-all.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realDuang/leetcode-in-javascript.git"
  },
  "keywords": [
    "leetcode"
  ],
  "author": "Duang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/realDuang/leetcode-in-javascript/issues"
  },
  "homepage": "https://github.com/realDuang/leetcode-in-javascript#readme"
}
